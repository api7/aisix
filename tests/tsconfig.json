{
  "compilerOptions": {
    "target": "esnext",
    "module": "nodenext",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "types": [
      "vitest/globals",
      "vitest/importMeta",
      "vitest",
      "node"
    ],
  },
  "include": [
    "**/*.ts"
  ]
}
